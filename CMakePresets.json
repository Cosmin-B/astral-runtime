{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development Build",
      "description": "Debug build with tests and benchmarks enabled",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ASTRAL_BUILD_TESTS": "ON",
        "ASTRAL_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "dev-cuda",
      "displayName": "Development (CUDA)",
      "description": "Debug build with CUDA backend enabled (requires CUDA toolkit)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/dev-cuda",
      "cacheVariables": {
        "ASTRAL_ENABLE_CUDA": "ON",
        "ASTRAL_CUDA_ARCHITECTURES": "75;80;86;89;90",
        "ASTRAL_CUDA_FORCE_CUBLAS": "OFF",
        "ASTRAL_CUDA_FORCE_MMQ": "OFF"
      }
    },
    {
      "name": "dev-cuda-cublas",
      "displayName": "Development (CUDA, cuBLAS)",
      "description": "Debug build with CUDA enabled and GGML_CUDA_FORCE_CUBLAS=ON",
      "inherits": "dev-cuda",
      "binaryDir": "${sourceDir}/build/dev-cuda-cublas",
      "cacheVariables": {
        "ASTRAL_CUDA_FORCE_CUBLAS": "ON",
        "ASTRAL_CUDA_FORCE_MMQ": "OFF"
      }
    },
    {
      "name": "dev-cuda-mmq",
      "displayName": "Development (CUDA, MMQ)",
      "description": "Debug build with CUDA enabled and GGML_CUDA_FORCE_MMQ=ON",
      "inherits": "dev-cuda",
      "binaryDir": "${sourceDir}/build/dev-cuda-mmq",
      "cacheVariables": {
        "ASTRAL_CUDA_FORCE_CUBLAS": "OFF",
        "ASTRAL_CUDA_FORCE_MMQ": "ON"
      }
    },
    {
      "name": "dev-prof",
      "displayName": "Development (Profiling)",
      "description": "Debug build with Tracy enabled (requires external/tracy submodule)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/dev-prof",
      "cacheVariables": {
        "ASTRAL_ENABLE_TRACY": "ON",
        "ASTRAL_ENABLE_TRACY_MICRO": "OFF"
      }
    },
    {
      "name": "dev-prof-cuda",
      "displayName": "Development (Profiling, CUDA)",
      "description": "Debug build with Tracy + CUDA backend enabled",
      "inherits": "dev-prof",
      "binaryDir": "${sourceDir}/build/dev-prof-cuda",
      "cacheVariables": {
        "ASTRAL_ENABLE_CUDA": "ON"
      }
    },
    {
      "name": "dev-prof-micro",
      "displayName": "Development (Profiling, Micro)",
      "description": "Debug build with Tracy enabled + micro zones (higher overhead)",
      "inherits": "dev-prof",
      "binaryDir": "${sourceDir}/build/dev-prof-micro",
      "cacheVariables": {
        "ASTRAL_ENABLE_TRACY_MICRO": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release Build",
      "description": "Optimized release build without tests",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ASTRAL_BUILD_TESTS": "OFF",
        "ASTRAL_BUILD_BENCHMARKS": "OFF",
        "ASTRAL_BUILD_STATIC_LIB": "ON",
        "ASTRAL_BUILD_SHARED_LIB": "ON"
      }
    },
    {
      "name": "release-cuda",
      "displayName": "Release (CUDA)",
      "description": "Release build with CUDA backend enabled (requires CUDA toolkit)",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-cuda",
      "cacheVariables": {
        "ASTRAL_ENABLE_CUDA": "ON",
        "ASTRAL_CUDA_ARCHITECTURES": "75;80;86;89;90",
        "ASTRAL_CUDA_FORCE_CUBLAS": "OFF",
        "ASTRAL_CUDA_FORCE_MMQ": "OFF"
      }
    },
    {
      "name": "release-prof",
      "displayName": "Release (Profiling)",
      "description": "Release build with Tracy enabled (requires external/tracy submodule)",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-prof",
      "cacheVariables": {
        "ASTRAL_ENABLE_TRACY": "ON",
        "ASTRAL_ENABLE_TRACY_MICRO": "OFF"
      }
    },
    {
      "name": "release-prof-cuda",
      "displayName": "Release (Profiling, CUDA)",
      "description": "Release build with Tracy + CUDA backend enabled",
      "inherits": "release-prof",
      "binaryDir": "${sourceDir}/build/release-prof-cuda",
      "cacheVariables": {
        "ASTRAL_ENABLE_CUDA": "ON"
      }

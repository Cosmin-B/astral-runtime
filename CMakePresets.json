      "name": "unity-plugin",
      "displayName": "Unity Plugin Build",
      "description": "Build Unity native plugin",
      "binaryDir": "${sourceDir}/build/unity",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LLAMA_CPP_DIR": "${sourceDir}/external/llama.cpp",
        "ASTRAL_BUILD_TESTS": "OFF",
        "ASTRAL_BUILD_BENCHMARKS": "OFF",
        "ASTRAL_BUILD_UNITY_PLUGIN": "ON",
        "ASTRAL_BUILD_STATIC_LIB": "OFF",
        "ASTRAL_BUILD_SHARED_LIB": "ON"
      }
    },
    {
      "name": "unity-plugin-android-arm64",
      "displayName": "Unity Plugin (Android arm64)",
      "description": "Build Unity native plugin for Android arm64-v8a (requires ANDROID_NDK_HOME; v0.1.1)",
      "binaryDir": "${sourceDir}/build/unity-android-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-21",
        "LLAMA_CPP_DIR": "${sourceDir}/external/llama.cpp",
        "ASTRAL_BUILD_TESTS": "OFF",
        "ASTRAL_BUILD_BENCHMARKS": "OFF",
        "ASTRAL_BUILD_UNITY_PLUGIN": "ON",
        "ASTRAL_BUILD_STATIC_LIB": "OFF",
        "ASTRAL_BUILD_SHARED_LIB": "ON"
      }
    },
    {
      "name": "unity-plugin-ios-arm64",
      "displayName": "Unity Plugin (iOS arm64)",
      "description": "Build Unity native plugin for iOS device arm64 (Xcode; v0.1.1)",

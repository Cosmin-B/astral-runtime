      "displayName": "Release (Profiling, Micro)",
      "description": "Release build with Tracy enabled + micro zones (higher overhead)",
      "inherits": "release-prof",
      "binaryDir": "${sourceDir}/build/release-prof-micro",
      "cacheVariables": {
        "ASTRAL_ENABLE_TRACY_MICRO": "ON"
      }
